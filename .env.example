# ===========================================================================
# Environment template — copy to .env and fill in real values.
#   cp .env.example .env
# NEVER commit the real .env. Every secret below is a PLACEHOLDER; the
# production fail-fast guard (app/core/config.py) refuses to boot if any of
# these dev defaults survive into APP_ENV=production.
# ===========================================================================

# ------------------------------------------------------------------ #
# Application identity
# ------------------------------------------------------------------ #
APP_NAME=hotel-marketplace
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------ #
# Security / cryptography  (generate strong, unique values per env)
# ------------------------------------------------------------------ #
SECRET_KEY=change-me-min-32-chars
JWT_SECRET_KEY=change-me-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Salt for hashing guest registry numbers. NEVER reuse SECRET_KEY.
REGISTRY_HASH_SALT=change-me-min-32-chars

# ------------------------------------------------------------------ #
# PostgreSQL — runtime role (created by the Alembic RLS revision).
# Port 5433/55440 etc. must match docker-compose.yml.
# ------------------------------------------------------------------ #
POSTGRES_HOST=localhost
POSTGRES_PORT=55440
POSTGRES_USER=app_runtime
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hotel_marketplace
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_ECHO=false

# Police-realm engine — separate LOGIN role.
POSTGRES_POLICE_USER=police_runtime
POSTGRES_POLICE_PASSWORD=change-me

# Migrations connect as the SCHEMA OWNER (never app_runtime). Read by
# alembic/env.py; not part of app Settings.
MIGRATIONS_DATABASE_URL=postgresql+psycopg://OWNER:PASSWORD@localhost:55440/hotel_marketplace

# ------------------------------------------------------------------ #
# Redis
# ------------------------------------------------------------------ #
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ------------------------------------------------------------------ #
# Government integrations (KHUR registry, e-Mongolia OAuth)
# GOV_USE_MOCKS=true wires the deterministic mock adapters. MUST be false
# in production (fail-fast enforced).
# ------------------------------------------------------------------ #
GOV_USE_MOCKS=true
KHUR_API_BASE_URL=https://xyp.gov.mn/api/v1
KHUR_API_KEY=change-me
EMONGOLIA_AUTH_BASE_URL=https://sso.e-mongolia.mn/oauth2
EMONGOLIA_CLIENT_ID=change-me
EMONGOLIA_CLIENT_SECRET=change-me
EMONGOLIA_REDIRECT_URI=http://localhost:8000/api/v1/auth/emongolia/callback
EMONGOLIA_STATE_TTL_SECONDS=600

# ------------------------------------------------------------------ #
# Payments / escrow
# ------------------------------------------------------------------ #
IDEMPOTENCY_TTL_SECONDS=86400

# ------------------------------------------------------------------ #
# Janitor (background sweeps for abandoned checkouts)
# ------------------------------------------------------------------ #
JANITOR_INTERVAL_SECONDS=300
PENDING_PAYMENT_TTL_MINUTES=15

# ------------------------------------------------------------------ #
# Business rules
# ------------------------------------------------------------------ #
PLATFORM_COMMISSION_RATE=0.05
PLATFORM_CURRENCY=MNT
